{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>druidfi/renovate-config:global"
  ],
  "baseBranchPatterns": [
    "main"
  ],
  "constraints": {
    "php": "8.1.*"
  },
  "enabled": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^docker-bake\\.hcl$/"],
      "matchStrings": [
        "(?:docker-image://mautic/mautic:|\\$\\{REPO_BASE\\}(?:-dxp)?:)(?<currentValue>5\\.\\d+\\.\\d+)(?:-apache)?"
      ],
      "depNameTemplate": "mautic/mautic-5-bake",
      "packageNameTemplate": "mautic/mautic",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^docker-bake\\.hcl$/"],
      "matchStrings": [
        "(?:docker-image://mautic/mautic:|\\$\\{REPO_BASE\\}(?:-dxp)?:)(?<currentValue>7\\.\\d+\\.\\d+)(?:-apache)?"
      ],
      "depNameTemplate": "mautic/mautic-7-bake",
      "packageNameTemplate": "mautic/mautic",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["mautic/mautic-5-bake"],
      "allowedVersions": "/^5\\./",
      "groupName": "Mautic 5 upstream image",
      "labels": ["docker", "mautic"]
    },
    {
      "matchDepNames": ["mautic/mautic-7-bake"],
      "allowedVersions": "/^7\\./",
      "groupName": "Mautic 7 upstream image",
      "labels": ["docker", "mautic"]
    }
  ]
}
